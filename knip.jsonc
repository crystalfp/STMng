{
  "$schema": "https://unpkg.com/knip@5/schema-jsonc.json",
  "entry": [
    "src/main.ts",
    "src/electron/main.ts",
    "src/electron/preload.ts",
    "src/components/*.vue",
    "src/ui/*.vue",
    "src/router/index.ts",
    "src/electron/fingerprint/Worker.ts"
  ],
  "project": ["src/**/*.{js,ts,vue}"],
  "ignoreBinaries": [
    "start",
    "oxlint",
    "vue-mess-detector",
    "dot",
    "node-gyp"
  ],
  "ignoreDependencies": [
    "vue-docgen-cli",
    "@mdi/svg",
    "node-addon-api",
    "typedoc",
    "typedoc-plugin-vue",
    "typedoc-plugin-missing-exports",
    "postcss-scss",
    "vite-plugin-dts",
    "@rollup/plugin-commonjs",
    "@rollup/plugin-node-resolve",
    "@rollup/plugin-terser",
    "@rollup/plugin-typescript",
    "oxlint-tsgolint"
  ],
  // "includeEntryExports": true,
  "ignore": ["**/KDtree.d.ts"],
  "oxlint": true,
  "rollup": true,
  "include": ["classMembers"],
   "tags": ["-knipIgnore"]
}
