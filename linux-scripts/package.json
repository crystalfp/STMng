{
  "name": "stm-ng",
  "description": "See The Molecule new generation (STMng) is a chemical and crystallographic structure visualization and analysis tool that inherits some functionalities of STM4",
  "productName": "STMng",
  "private": true,
  "main": "dist-electron/main.js",
  "version": "1.58.0",
  "author": "Mario Valle <mvalle@ikmail.com>",
  "license": "ISC",
  "homepage": "https://www.electronjs.org",
  "nodeGypRebuild": true,
  "gypfile": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "node-gyp rebuild && electron-builder install-app-deps && rolldown -c rolldown.config.mjs",
    "build": "golar typecheck && vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "preview": "vite preview",
    "lint": "eslint --concurrency=auto -f codeframe src",
    "stylelint": "stylelint ./src/App.vue ./src/**/*.vue ./src/styles/* ./public/doc/**/*.css",
    "start": "start /D .\\release\\win\\%npm_package_version%\\win-unpacked STMng.exe",
    "oxlint": "oxlint -c ./oxlint.json --tsconfig=tsconfig.json",
    "mess": "vue-mess-detector analyze src --group=file --ignore=elementAttributeOrder,shortVariableName,multiAttributeElements,elseCondition"
  },
  "dependencies": {
    "@derschmale/tympanum": "^1.3.6",
    "@electron-toolkit/preload": "^3.0.2",
    "@unovis/ts": "^1.6.4",
    "@unovis/vue": "^1.6.4",
    "@vue-flow/core": "^1.48.2",
    "camera-controls": "^3.1.2",
    "commander": "^14.0.3",
    "custom-electron-titlebar": "^4.4.1",
    "electron-log": "^5.4.3",
    "mathjs": "^15.2.0",
    "mediabunny": "^1.40.1",
    "pinia": "^3.0.4",
    "three": "^0.183.2",
    "three-viewport-gizmo": "^2.2.0",
    "tmp": "^0.2.5",
    "troika-three-text": "^0.52.4",
    "valibot": "^1.3.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.5",
    "workerpool": "^10.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@golar/vue": "^0.1.5",
    "@mdi/font": "^7.4.47",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/three": "^0.183.1",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "eslint-formatter-codeframe": "^7.32.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "golar": "^0.1.5",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.2.0",
    "postcss-html": "^1.8.1",
    "rolldown": "^1.0.0-rc.15",
    "stylelint": "^17.7.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typedoc-plugin-vue": "^1.5.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-clean-pattern": "^1.0.6",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-docgen-cli": "^4.79.0",
    "vue-eslint-parser": "^10.4.0"
  }
}
