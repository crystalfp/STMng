{
  "name": "stm-ng",
  "description": "See The Molecule new generation",
  "private": true,
  "main": "dist-electron/main.js",
  "version": "0.12.2",
  "author": "Mario Valle <mvalle@ikmail.com>",
  "license": "ISC",
  "homepage": "https://www.electronjs.org",
  "nodeGypRebuild": true,
  "gypfile": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build && electron-builder",
    "prebuild": "node-gyp rebuild && electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "preview": "vite preview",
    "oldlint": "set ESLINT_USE_FLAT_CONFIG=false&& eslint -c ./eslint.yaml --color -f codeframe src/**/*.ts src/**/*.vue",
    "lint": "set ESLINT_USE_FLAT_CONFIG=true&& eslint --config eslint.config.mjs -f codeframe src/**",
    "stylelint": "stylelint ./src/App.vue ./src/**/*.vue ./src/styles/*",
    "madge": "node ../ExtractTSfromVue/index.js",
    "start": "start ./release/%npm_package_version%/win-unpacked/STMng.exe"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
