{
  "name": "stm-ng",
  "description": "See The Molecule new generation (STMng) is a chemical and crystallographic structure visualization and analysis tool that inherits some functionalities of STM4",
  "productName": "STMng",
  "private": true,
  "main": "dist-electron/main.js",
  "version": "1.56.5",
  "author": "Mario Valle <mvalle@ikmail.com>",
  "license": "ISC",
  "homepage": "https://www.electronjs.org",
  "nodeGypRebuild": true,
  "gypfile": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "node-gyp rebuild && electron-builder install-app-deps && .\\rolldown.bat",
    "build": "golar && vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "preview": "vite preview",
    "lint": "eslint --concurrency=8 -f codeframe src",
    "stylelint": "stylelint ./src/App.vue ./src/**/*.vue ./src/styles/* ./public/doc/**/*.css",
    "start": "start /D .\\release\\win\\%npm_package_version%\\win-unpacked STMng.exe",
    "oxlint": "oxlint -c ./oxlint.json --tsconfig=tsconfig.json",
    "migrate": "migrate --type-aware --js-plugins",
    "mess": "vue-mess-detector analyze src --exclude=src/cpp,KDtree.js --ignore=elementAttributeOrder,shortVariableName,multiAttributeElements,elseCondition",
    "cruise": "depcruise -v -T dot -x cpp/ src | dot -T svg | depcruise-wrap-stream-in-html > doc/dependency-graph.html",
    "cruise:err": "depcruise -T err -x cpp/ src",
    "cruise:err2": "depcruise -T err-html -x cpp/ src > doc/dependency-errors.html",
    "cruise:archi": "depcruise -v -T archi -x cpp/ src | dot -T svg | depcruise-wrap-stream-in-html > doc/dependency-graph.html",
    "cruise:flat": "depcruise -v -T flat -x cpp/ src | dot -T svg | depcruise-wrap-stream-in-html > doc/dependency-graph.html",
    "test": "vitest run"
  },
  "dependencies": {
    "@derschmale/tympanum": "^1.3.6",
    "@electron-toolkit/preload": "^3.0.2",
    "@mdi/js": "^7.4.47",
    "@unovis/ts": "^1.6.4",
    "@unovis/vue": "^1.6.4",
    "@vue-flow/core": "^1.48.2",
    "camera-controls": "^3.1.2",
    "commander": "^14.0.3",
    "custom-electron-titlebar": "^4.2.8",
    "electron-log": "^5.4.3",
    "html-to-image": "^1.11.13",
    "mathjs": "^15.1.1",
    "mediabunny": "^1.39.2",
    "pinia": "^3.0.4",
    "three": "^0.183.2",
    "three-viewport-gizmo": "^2.2.0",
    "tmp": "^0.2.5",
    "troika-three-text": "^0.52.4",
    "valibot": "^1.2.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.2",
    "workerpool": "^10.0.1"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@golar/vue": "^0.0.16",
    "@mdi/svg": "^7.4.47",
    "@oxlint/migrate": "^1.56.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/three": "^0.183.1",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@typescript/native-preview": "^7.0.0-dev.20260317.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/ui": "^4.1.0",
    "dependency-cruiser": "^17.3.9",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-formatter-codeframe": "^7.32.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "golar": "^0.0.16",
    "node-addon-api": "^8.6.0",
    "node-gyp": "^12.2.0",
    "oxlint-tsgolint": "^0.17.0",
    "postcss-html": "^1.8.1",
    "rolldown-vite": "^7.3.1",
    "stylelint": "^17.4.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-missing-exports": "^4.1.2",
    "typedoc-plugin-vue": "^1.5.1",
    "typescript": "^5.9.3",
    "vite-plugin-clean-pattern": "^1.0.6",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitest": "^4.1.0",
    "vue-docgen-cli": "^4.79.0",
    "vue-eslint-parser": "^10.4.0"
  }
}
