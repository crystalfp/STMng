{
  "name": "stm-ng",
  "description": "See The Molecule new generation (STMng) is a chemical and crystallographic structure visualization and analysis tool that inherits some functionalities of STM4",
  "private": true,
  "main": "dist-electron/main.js",
  "version": "1.42.5",
  "author": "Mario Valle <mvalle@ikmail.com>",
  "license": "ISC",
  "homepage": "https://www.electronjs.org",
  "nodeGypRebuild": true,
  "gypfile": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "node-gyp rebuild && electron-builder install-app-deps && sh ./rollup.sh",
    "build": "vue-tsc && vite build && electron-builder",
    "build:fix": "vue-tsc && electron-builder install-app-deps && sh ./rollup.sh && vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "preview": "vite preview",
    "lint": "eslint --concurrency=auto -f codeframe src",
    "stylelint": "stylelint ./src/App.vue ./src/**/*.vue ./src/styles/* ./public/doc/**/*.css",
    "start": "start /D .\\release\\win\\%npm_package_version%\\win-unpacked STMng.exe",
    "oxlint": "oxlint -c ./oxlint.json --tsconfig=tsconfig.json",
    "mess": "vue-mess-detector analyze src --exclude=src/cpp,KDtree.js --ignore=elementAttributeOrder,shortVariableName,multiAttributeElements,elseCondition",
    "cruise": "depcruise -v -T dot -x cpp/ src | dot -T svg | depcruise-wrap-stream-in-html > doc/dependency-graph.html",
    "cruise:err": "depcruise -T err -x cpp/ src",
    "cruise:err2": "depcruise -T err-html -x cpp/ src > doc/dependency-errors.html",
    "cruise:archi": "depcruise -v -T archi -x cpp/ src | dot -T svg | depcruise-wrap-stream-in-html > doc/dependency-graph.html",
    "cruise:flat": "depcruise -v -T flat -x cpp/ src | dot -T svg | depcruise-wrap-stream-in-html > doc/dependency-graph.html"
  },
  "dependencies": {
    "@derschmale/tympanum": "^1.3.6",
    "@electron-toolkit/preload": "^3.0.2",
    "@mdi/js": "^7.4.47",
    "@vue-flow/core": "^1.46.2",
    "camera-controls": "^3.1.0",
    "chart.js": "^4.5.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "commander": "^14.0.0",
    "custom-electron-titlebar": "^4.2.8",
    "electron-log": "^5.4.3",
    "mathjs": "^14.6.0",
    "pinia": "^3.0.3",
    "three": "^0.179.1",
    "three-viewport-gizmo": "^2.2.0",
    "tmp": "^0.2.5",
    "troika-three-text": "^0.52.4",
    "valibot": "^1.1.0",
    "vue": "^3.5.20",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.1",
    "vuetify": "^3.9.6",
    "workerpool": "^9.3.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@mdi/svg": "^7.4.47",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@stylistic/eslint-plugin": "^5.3.1",
    "@types/eslint": "^9.6.1",
    "@types/three": "^0.179.0",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "dependency-cruiser": "^17.0.1",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.34.0",
    "eslint-formatter-codeframe": "^7.32.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-depend": "^1.2.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-tsdoc": "^0.4.0",
    "eslint-plugin-unicorn": "^60.0.0",
    "eslint-plugin-vue": "^10.4.0",
    "node-addon-api": "^8.5.0",
    "postcss-html": "^1.8.0",
    "stylelint": "^16.23.1",
    "stylelint-config-recommended-scss": "^16.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-config-standard-vue": "^1.0.0",
    "typedoc": "^0.28.12",
    "typedoc-plugin-missing-exports": "^4.1.0",
    "typedoc-plugin-vue": "^1.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-plugin-clean-pattern": "^1.0.6",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-vue-devtools": "^8.0.1",
    "vue-docgen-cli": "^4.79.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.6"
  }
}
