{
  "name": "stm-ng",
  "description": "See The Molecule new generation is a chemical structure visualizer that inherits some functionalities of STM4",
  "private": true,
  "main": "dist-electron/main.js",
  "version": "1.15.1",
  "author": "Mario Valle <mvalle@ikmail.com>",
  "license": "ISC",
  "homepage": "https://www.electronjs.org",
  "nodeGypRebuild": true,
  "gypfile": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build-ok": "vue-tsc && vite build && electron-builder",
    "prebuild": "node-gyp rebuild && electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "preview": "vite preview",
    "lint": "eslint -f codeframe src",
    "stylelint": "stylelint ./src/App.vue ./src/**/*.vue ./src/styles/*",
    "madge": "madge --extensions ts,vue --ts-config tsconfig.json -i madge.png --warning src",
    "start": "start /D .\\release\\win\\%npm_package_version%\\win-unpacked STMng.exe",
    "oxlint": "oxlint -c ./oxlint.json --ignore-pattern=save"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "camera-controls": "^2.9.0",
    "chart.js": "^4.4.7",
    "chartjs-plugin-datalabels": "^2.2.0",
    "commander": "^12.1.0",
    "custom-electron-titlebar": "^4.2.8",
    "electron-log": "^5.2.4",
    "js-yaml": "^4.1.0",
    "pinia": "^2.3.0",
    "three": "^0.171.0",
    "three-viewport-gizmo": "^2.0.2",
    "tmp": "^0.2.3",
    "troika-three-text": "^0.52.2",
    "valibot": "^0.42.1",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.0",
    "vuetify": "^3.7.5"
  },
  "devDependencies": {
    "@alasdair/eslint-plugin-max-len": "^1.1.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@eslint/js": "^9.16.0",
    "@mdi/svg": "^7.4.47",
    "@stylistic/eslint-plugin": "^2.12.1",
    "@types/eslint": "^9.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/three": "^0.170.0",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.16.0",
    "eslint-formatter-codeframe": "^7.32.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-depend": "^0.12.0",
    "eslint-plugin-deprecate": "^0.8.5",
    "eslint-plugin-electron-extension": "^1.1.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^2.7.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.1",
    "eslint-plugin-tsdoc": "^0.4.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "eslint-plugin-vue": "^9.32.0",
    "node-addon-api": "^8.3.0",
    "node-gyp": "^11.0.0",
    "postcss-html": "^1.7.0",
    "stylelint": "^16.11.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typedoc": "^0.27.4",
    "typedoc-plugin-missing-exports": "^3.1.0",
    "typedoc-plugin-vue": "^1.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-vue-devtools": "^7.6.8",
    "vue-docgen-cli": "^4.79.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  }
}
