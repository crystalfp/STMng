{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "stm-ng",
  "description": "See The Molecule new generation (STMng) is a chemical and crystallographic structure visualization and analysis tool that inherits some functionalities of STM4",
  "productName": "STMng",
  "private": true,
  "main": "dist-electron/main.js",
  "version": "1.66.1",
  "author": "Mario Valle <mvalle@ikmail.com>",
  "license": "ISC",
  "homepage": "https://github.com/crystalfp/STMng",
  "repository": "github:crystalfp/STMng",
  "nodeGypRebuild": true,
  "gypfile": true,
  "desktopName": "com.example.STMng.desktop",
  "scripts": {
    "dev": "vite",
    "prebuild": "node-gyp rebuild && electron-builder install-app-deps && sh rolldown.sh",
    "build": "golar typecheck && vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "preview": "vite preview",
    "lint": "eslint --concurrency=8 -f codeframe src",
    "stylelint": "stylelint ./src/App.vue ./src/**/*.vue ./src/styles/* ./public/doc/**/*.css",
    "start": "start /D .\\release\\%npm_package_version%\\win-unpacked STMng.exe",
    "oxlint": "oxlint -c ./oxlint.json --tsconfig=tsconfig.json",
    "migrate": "migrate --type-aware --js-plugins --with-nursery",
    "mess": "vue-mess-detector analyze src --exclude=src/cpp,KDtree.js --ignore=elementAttributeOrder,shortVariableName,multiAttributeElements,elseCondition",
    "cruise": "depcruise -v -T dot -x cpp/ src | dot -T svg | depcruise-wrap-stream-in-html > doc/dependency-graph.html",
    "cruise:err": "depcruise -T err -x cpp/ src",
    "cruise:err2": "depcruise -T err-html -x cpp/ src > doc/dependency-errors.html",
    "cruise:archi": "depcruise -v -T archi -x cpp/ src | dot -T svg | depcruise-wrap-stream-in-html > doc/dependency-graph.html",
    "cruise:flat": "depcruise -v -T flat -x cpp/ src | dot -T svg | depcruise-wrap-stream-in-html > doc/dependency-graph.html",
    "test": "vitest run"
  },
  "dependencies": {
    "@derschmale/tympanum": "^1.3.6",
    "@electron-toolkit/preload": "^3.0.2",
    "@unovis/ts": "^1.6.6",
    "@unovis/vue": "^1.6.6",
    "@vue-flow/core": "^1.48.2",
    "camera-controls": "^3.1.2",
    "commander": "^15.0.0",
    "custom-electron-titlebar": "^4.4.1",
    "delaunator": "^5.1.0",
    "electron-log": "^5.4.4",
    "mathjs": "^15.2.0",
    "mediabunny": "^1.49.0",
    "pinia": "^3.0.4",
    "three": "^0.185.0",
    "three-viewport-gizmo": "^2.2.0",
    "tmp": "^0.2.7",
    "troika-three-text": "^0.52.4",
    "valibot": "^1.4.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vuetify": "^4.1.2",
    "workerpool": "^10.0.2"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@golar/vue": "^0.1.8",
    "@mdi/font": "^7.4.47",
    "@oxlint/migrate": "^1.71.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/three": "^0.185.0",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript/native-preview": "^7.0.0-dev.20260624.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "dependency-cruiser": "^18.0.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "eslint-formatter-codeframe": "^7.32.2",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^69.0.0",
    "eslint-plugin-vue": "^10.9.2",
    "golar": "^0.1.8",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^13.0.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "postcss-html": "^1.8.1",
    "rolldown": "^1.1.3",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typedoc-plugin-vue": "^1.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-clean-pattern": "^1.0.6",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-docgen-cli": "^4.79.0",
    "vue-eslint-parser": "^10.4.1",
    "vue-mess-detector": "^0.68.1"
  },
  "allowScripts": {
    "esbuild": false,
    "maplibre-gl": false,
    "vue-demi": false,
    "unrs-resolver": false,
    "electron-winstaller": false
  }
}
