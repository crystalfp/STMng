{
  "plugins": [
    "unicorn",
    "typescript",
    "oxc",
    "promise",
    "node",
    "security"
  ],
  "categories": {
    "style": "warn",
    "suspicious": "warn",
    "restriction": "warn",
    "correctness": "warn",
    "pedantic": "warn",
    "perf": "warn",
    "nursery": "warn"
  },
  "rules": {
    "numeric-separators-style": 0,
    "filename-case": 0,
    "sort-keys": 0,
    "sort-imports": 0,
    "no-async-await": 0,
    "yoda": 0,
    "no-plusplus": 0,
    "no-magic-numbers": 0,
    "prefer-await-to-then": 0,
    "prefer-await-to-callbacks": 0,
    "no-undefined": 0,
    "no-ternary": 0,
    "default-case": 0,
    "no-zero-fractions": 0,
    "approx-constant": 0,
    "curly": 0,
    "no-continue": 0,
    "no-optional-chaining": 0,
    "max-params": 0,
    "throw-new-error": 0,
    "no-void": 0,
    "explicit-function-return-type": 0,
    "no-bitwise": 0,
    "init-declarations": 0,
    "no-non-null-assertion": 0,
    "guard-for-in": 0,
    "consistent-indexed-object-style": 0,
    "bad-bitwise-operator": 0,
    "catch-or-return": 0,
    "no-multi-assign": 0,
    "avoid-new": 0,
    "no-rest-spread-properties": 0,
    "operator-assignment": 0,
    "max-lines": 0,
    "max-lines-per-function": 0,
    "max-depth": 0,
    "max-nested-callbacks": 0,
    "new-for-builtins": 0,
    "sort-vars": 0,
    "max-classes-per-file": 0,
    "no-await-in-loop": 0
  },
  "settings": {
  },
  "env": {
    "builtin": true,
    "shared-node-browser": true,
    "browser": true,
    "node": true,
    "es2024": true
  },
  "globals": {
    "defineProps": "readonly",
    "defineModel": "readonly",
    "withDefaults": "readonly",
    "defineEmits": "readonly",
    "process": "readonly",
    "Record": "readonly",
    "Buffer": "readonly",
    "ReturnType": "readonly",
    "NodeJS": "readonly",
    "window": "readonly",
    "ArrayBufferLike": "readonly"
  },
  "ignorePatterns": [
    "src/electron/fingerprint/KDtree*",
    "save/*.*",
    "save/**/*.*",
    "matrix.ts"
  ]
}
